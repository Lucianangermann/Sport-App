# Copy this file to .env.local (gitignored) and fill in your real key.
# Get a key at https://console.anthropic.com → Settings → API Keys.
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional: override the endpoint in production (e.g. your own server-side proxy).
# In dev, leave this unset — the Vite proxy at /api/anthropic handles it.
# VITE_CLAUDE_ENDPOINT=https://your-backend.example.com/anthropic/v1/messages
